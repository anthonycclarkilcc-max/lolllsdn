# ============================================
# VERCEL ENVIRONMENT VARIABLES
# ============================================
# 
# IMPORTANT: DO NOT commit this file!
# Add these to Vercel Dashboard instead:
# Project Settings → Environment Variables
#
# ============================================

# Telegram Configuration
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE
TELEGRAM_CHAT_ID=YOUR_CHAT_ID_HERE

# Server Configuration  
SERVER_DOMAIN=yourdomain.com

# ============================================
# HOW TO GET TELEGRAM CREDENTIALS:
#
# 1. Message @BotFather on Telegram
# 2. Create new bot: /newbot
# 3. Copy the bot token (looks like: 1234567890:ABCdef...)
# 4. Send a message to your bot
# 5. Visit: https://api.telegram.org/botYOUR_TOKEN/getUpdates
# 6. Find "chat":{"id":123456789} - that's your CHAT_ID
#
# ============================================
